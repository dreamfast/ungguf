FROM nvcr.io/nvidia/pytorch:26.02-py3

ARG HOST_UID=1000
ARG HOST_GID=1000

WORKDIR /app

ENV PIP_CACHE_DIR=/root/.cache/pip

COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip pip3 install -r requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip pip3 install vllm && \
    pip3 uninstall -y torchao 2>/dev/null || true && \
    pip3 install 'transformers>=5.5.3' 'huggingface_hub>=1.5.0,<2.0' && \
    pip3 install bitsandbytes accelerate

# Create non-root user matching host UID/GID
RUN groupadd -g "$HOST_GID" appuser 2>/dev/null || true && \
    useradd -m -u "$HOST_UID" -g "$HOST_GID" -s /bin/bash appuser 2>/dev/null || true

COPY --chown=${HOST_UID}:${HOST_GID} src/ ./src/
COPY --chown=${HOST_UID}:${HOST_GID} gguf_metadata_dump.py .

ENV PYTHONPATH=/app
WORKDIR /app/src

USER ${HOST_UID}:${HOST_GID}

CMD ["python3", "vllm_sanity.py", "--help"]
